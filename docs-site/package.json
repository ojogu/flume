{
  "name": "flume-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate-spec && npm run generate-api && next build",
    "validate-spec": "tsx ../scripts/validate-openapi.ts",
    "generate-api": "tsx scripts/generate-docs.ts",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "fumadocs-ui": "^16.0.0",
    "fumadocs-core": "^16.0.0",
    "fumadocs-openapi": "^6.0.0",
    "lucide-react": "^0.400.0",
    "framer-motion": "^12.40.0",
    "@fontsource/dm-sans": "^5.1.0",
    "@fontsource/instrument-serif": "^5.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^4.2.0",
    "@tailwindcss/postcss": "^4.2.0",
    "tsx": "^4.15.6"
  }
}
